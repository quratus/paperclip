# Paperclip — Environment Configuration Example
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# -----------------------------------------------------------------------------
# Core server
# -----------------------------------------------------------------------------

# Postgres connection string
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip

# Server port
PORT=3100

# Whether to serve the built-in UI
SERVE_UI=false

# Public URL used for auth callbacks and external links
# PAPERCLIP_PUBLIC_URL=http://localhost:3100

# -----------------------------------------------------------------------------
# Auth / sessions
# -----------------------------------------------------------------------------

# Better-Auth secret (change in production!)
BETTER_AUTH_SECRET=change-me-in-production

# Optional: trusted origins for Better-Auth
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional: secret used to sign agent JWTs
# PAPERCLIP_AGENT_JWT_SECRET=change-me-in-production

# Optional: agent JWT TTL and audience/issuer
# PAPERCLIP_AGENT_JWT_TTL_SECONDS=3600
# PAPERCLIP_AGENT_JWT_ISSUER=paperclip
# PAPERCLIP_AGENT_JWT_AUDIENCE=paperclip-agents

# -----------------------------------------------------------------------------
# Network / bind / exposure
# -----------------------------------------------------------------------------

# Deployment mode: local_trusted | authenticated
# PAPERCLIP_DEPLOYMENT_MODE=local_trusted

# Exposure: local | tailnet | lan | public
# PAPERCLIP_DEPLOYMENT_EXPOSURE=local

# Bind mode: loopback | lan | tailnet
# PAPERCLIP_BIND=loopback

# Optional: explicit bind host / listen host
# PAPERCLIP_BIND_HOST=127.0.0.1
# PAPERCLIP_LISTEN_HOST=127.0.0.1

# Optional: Tailscale bind host
# PAPERCLIP_TAILNET_BIND_HOST=100.64.0.8

# Optional: comma-separated list of allowed hostnames
# PAPERCLIP_ALLOWED_HOSTNAMES=localhost,my-tailnet.ts.net

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Storage provider: local | s3
# PAPERCLIP_STORAGE_PROVIDER=local

# Local storage directory
# PAPERCLIP_STORAGE_LOCAL_DIR=/Users/$USER/.paperclip/storage

# S3 settings (only when PAPERCLIP_STORAGE_PROVIDER=s3)
# PAPERCLIP_STORAGE_S3_BUCKET=my-bucket
# PAPERCLIP_STORAGE_S3_REGION=us-east-1
# PAPERCLIP_STORAGE_S3_ENDPOINT=https://s3.amazonaws.com
# PAPERCLIP_STORAGE_S3_PREFIX=paperclip/
# PAPERCLIP_STORAGE_S3_FORCE_PATH_STYLE=false

# -----------------------------------------------------------------------------
# Secrets
# -----------------------------------------------------------------------------

# Optional: inline 32-byte master key for the secrets store
# PAPERCLIP_SECRETS_MASTER_KEY=base64:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=

# Optional: path to a file containing the master key
# PAPERCLIP_SECRETS_MASTER_KEY_FILE=/path/to/master.key

# Secrets provider: local | aws
# PAPERCLIP_SECRETS_PROVIDER=local

# Optional: refuse to start if secrets cannot be decrypted
# PAPERCLIP_SECRETS_STRICT_MODE=false

# -----------------------------------------------------------------------------
# Worktrees
# -----------------------------------------------------------------------------

# Optional: root directory for agent worktrees
# PAPERCLIP_WORKTREES_DIR=/Users/$USER/.paperclip/worktrees

# Optional: default start point (branch/ref) for new worktrees
# PAPERCLIP_WORKTREE_START_POINT=main

# -----------------------------------------------------------------------------
# Scheduler / heartbeat
# -----------------------------------------------------------------------------

# Optional: heartbeat scheduler interval
# HEARTBEAT_SCHEDULER_INTERVAL_MS=60000

# Optional: disable the heartbeat scheduler
# HEARTBEAT_SCHEDULER_ENABLED=true

# -----------------------------------------------------------------------------
# Paths / overrides
# -----------------------------------------------------------------------------

# Optional: Paperclip home / instance / config / context overrides
# PAPERCLIP_HOME=/Users/$USER/.paperclip
# PAPERCLIP_INSTANCE_ID=default
# PAPERCLIP_CONFIG=/path/to/config.json
# PAPERCLIP_CONTEXT=/path/to/context.json
